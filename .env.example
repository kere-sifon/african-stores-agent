# Copy to .env and adjust. Loaded automatically by config.py.

# ollama | bedrock
LLM_PROVIDER=bedrock

# ── Bedrock ───────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-haiku-4-5-20251001-v1:0
# Set to true if you use cross-region inference profile instead:
# BEDROCK_USE_REGIONAL=true
# BEDROCK_MODEL_ID_REGIONAL=us.anthropic.claude-haiku-4-5-20251001-v1:0
BEDROCK_MAX_TOKENS=4096

# ── Ollama (when LLM_PROVIDER=ollama) ─────────────────────────────────────────
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1:8b
# OLLAMA_TEMPERATURE=0
