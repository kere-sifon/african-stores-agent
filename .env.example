# Copy to .env and adjust. Loaded automatically by config.py.

# ollama | bedrock
LLM_PROVIDER=bedrock

# ── Bedrock ───────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0
BEDROCK_MAX_TOKENS=4096

# ── Storage: MongoDB Atlas (recommended for website backend + CI) ─────────────
STORAGE_BACKEND=mongodb
# Atlas → Connect → Drivers → Python — copy connection string
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=african_stores
MONGODB_COLLECTION=stores

# contact = address OR phone OR website | address = street address required only
STORE_CONTACT_RULE=contact

# Google Maps–biased search (DuckDuckGo site:google.com/maps + place URLs first)
MAPS_SEARCH_ENABLED=true
MAPS_SEARCH_RESULTS=6

# ── Storage: SQLite (local-only fallback) ─────────────────────────────────────
# STORAGE_BACKEND=sqlite
# DB_PATH=african_stores.db

# ── Ollama (when LLM_PROVIDER=ollama) ─────────────────────────────────────────
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1:8b
# OLLAMA_TEMPERATURE=0
